# Example environment for the Mentions pack.
# Bind this agent to a separate Telegram bot/account to keep surfaces separate.

# Identity / transport
AGENT_NAME=mentions
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=replace_me

# Kalshi API credentials
KALSHI_API_KEY=replace_me
KALSHI_API_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_DEMO_API_URL=https://demo-api.kalshi.co/trade-api/v2

# Set to 'demo' or 'prod'
KALSHI_ENV=demo

# Live news provider
NEWSAPI_KEY=replace_me

# Optional: if installed with `pip install -e .`, use either:
#   python -m openclaw ...
#   openclaw ...
