{
  // Example config for the official OpenClaw Gateway.
  // Telegram bot token is read from TELEGRAM_BOT_TOKEN in the environment.
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "127.0.0.1"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "heartbeat": {
        "every": "0m"
      },
      "models": {
        "openai-codex/gpt-5.4": {}
      }
    },
    "list": [
      {
        "id": "mentions",
        "default": true,
        "workspace": "/Users/nshrd/Documents/New project/openclaw-workspace",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "codex",
            "backend": "acpx",
            "mode": "persistent",
            "cwd": "/Users/nshrd/Documents/New project/openclaw-workspace"
          }
        }
      }
    ]
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "codex",
    "allowedAgents": [
      "codex"
    ],
    "maxConcurrentSessions": 4,
    "runtime": {
      "ttlMinutes": 120
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "historyLimit": 50,
      "replyToMode": "first",
      "linkPreview": true,
      "threadBindings": {
        "spawnAcpSessions": true
      },
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "messages": {
    "queue": {
      "mode": "collect",
      "debounceMs": 1000,
      "cap": 20,
      "drop": "summarize"
    }
  },
  "commands": {
    "native": "auto",
    "text": true,
    "bash": false,
    "config": false,
    "debug": false,
    "restart": false
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }
}
